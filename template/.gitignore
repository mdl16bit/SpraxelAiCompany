# Godot editor cache + import cache — all regenerated on every editor open.
# Committing them causes stale-path errors when files move and pointless diff noise.
.godot/

# Per-script .uid files are auto-generated by the editor. Tracking them just
# creates noise; Godot regenerates them on import.
*.gd.uid

# Spraxel offline-workflow runtime state
.factory/local-test-logs/
.factory/local-tests-status.json
.factory/reviews/

# CEO-local artifacts — MORNING.md, briefer intermediate state, anything
# the CEO reads but should never be checked in. Treat this dir as a
# personal scratch space owned by the human, regenerated by agents.
.factory/local/

# OS / editor cruft
.DS_Store
.vscode/
.idea/
*.swp
*~
