.DS_Store
__pycache__/
*.pyc
.venv/
venv/
.env
*.log
.idea/
.vscode/

# Runtime state — local-only, never committed
logs/
.locks/
.cache/
state/
.paused
.claude/*.lock

# Crew-agent worktrees — transient git worktrees created by run_agent.sh
# when the main game-repo checkout is on a feature branch. Removed at the
# end of each agent run; only present here transiently.
.worktrees/

# Reviewer output — ephemeral per-branch findings written by spraxel-reviewer;
# regenerated each review, never meant to be committed.
.factory/reviews/
